	"temperature": {
		"thermal-zone": 2,
		"interval": 3,
		"hwmon-path": "/sys/class/hwmon/hwmon3/temp2_input",
		"critical-threshold": 90,
		"format-critical": "’ü▒  {temperatureC} ┬░C",
