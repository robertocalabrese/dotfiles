{
	// ##########################
	// ## Global configuration ##
	// ##########################

	"layer": "top",
	"position": "top",

	"modules-left": [
		"custom/menu",
		"hyprland/workspaces",
		"hyprland/window"
	],

	"modules-center": [
		"clock",
		"custom/weather"
	],

	"modules-right": [
		"custom/packages",
		"custom/mediaplayer",
		"tray",
		"idle_inhibitor",
		"temperature",
		"cpu",
		"memory",
		"pulseaudio"
	],

	// ###############
	// ## Left side ##
	// ###############

	"custom/menu": {
		"format": "’āē",
		"tooltip": false,
		"on-click": "wofi --show drun"
	},

	"hyprland/workspaces" : {
		"active-only": false,
		"all-outputs": true,
		"format": "{}",
		"format-icons": {
			"urgent": "",
			"active": "",
			"default": ""
		},
		"persistent-workspaces": {
			 "*": 1
		},
		"on-click": "activate",
		"on-scroll-up": "hyprctl dispatch workspace e+1",
		"on-scroll-down": "hyprctl dispatch workspace e-1"
	},

	"hyprland/window": {
		"max-length": 60,
		"separate-outputs": true
	},

	// ############
	// ## Center ##
	// ############

	"clock": {
		"interval": 60,
		"format": "{:L%A %d %B %Y   -   %H:%M}",
		"max-length": 40,
		"tooltip": false
	},

	"custom/weather": {
		"format": "{}",
		"tooltip": false,
		"interval": 1800,
		"exec": "$HOME/.config/waybar/scripts/wttr.py",
		"on-click": "$HOME/.config/waybar/scripts/weather_forecast.sh",
		"return-type": "json"
	},

	// ################
	// ## Right side ##
	// ################

	"custom/packages": {
		"exec": "checkupdates | wc -l",
		"exec-if": "$HOME/.config/waybar/scripts/check_for_upgrades.sh 0",
		"format": "’ÅŁ {}",
		"interval": 45,
		//"on-click": "alacritty -e '.config/waybar/scripts/upgrade.sh'",
		"tooltip": false
	},

	"custom/mediaplayer": {
		"format": "{}",
		"return-type": "json",
		"max-length": 40,
		"escape": true,
		"on-click": "playerctl play-pause",
		"on-scroll-up": "playerctl previous",
		"on-scroll-down": "playerctl next",
		"exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null"
	},

	"tray": {
		"icon-size": 24,
		"spacing": 20
	},

	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "’ü░",
			"deactivated": "’ü«"
		},
		"tooltip": "true"
	},

