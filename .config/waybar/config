	// 	"tooltip-format-wifi": "ΎΘτ {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nΎΓΥ {bandwidthUpBits} ΎΑβ {bandwidthDownBits}",
	// 	"interval": 10
	// },

	"pulseaudio": {
		"format": "{icon} {volume} % {format_source}",
		"format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
		"format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
		"format-muted": "Ύγσ {format_source}",
		"format-source": "ΎΕ░ {volume} %",
		"format-source-muted": "ΎΕ▒",
		"format-icons": {
			"headphone": "ΎΑξ",
			"hands-free": "ΎΨΡ",
			"headset": "ΎΨΡ",
			"phone": "ΎΓΧ",
			"portable": "ΎΓΧ",
			"car": "ΎΗ╣",
			"default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
		},
		"on-click": "pavucontrol",
		"on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
		"on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
	}
}