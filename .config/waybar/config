{
	// ##########################
	// ## Global configuration ##
	// ##########################

	"layer": "top",
	"position": "top",

	"modules-left": [
		"custom/menu",
		"hyprland/workspaces",
		"hyprland/window"
	],

	"modules-center": [
		"clock"
	],

	"modules-right": [
		"custom/packages",
		"custom/mediaplayer",
		"tray",
		"idle_inhibitor",
		"temperature",
		"cpu",
		"memory",
		"pulseaudio"
	],

	// ###############
	// ## Left side ##
	// ###############

	"custom/menu": {
        "format": "ΎΔΚ",
        "tooltip": false,
        "on-click": "wofi --show drun"
    },

	"hyprland/workspaces" : {
		"active-only": false,
		"all-outputs": true,
		"format": "{}",
		"format-icons": {
			"urgent": "",
			"active": "",
			"default": ""
		},
		"persistent-workspaces": {
			 "*": 1
		},
		"on-click": "activate",
		"on-scroll-up": "hyprctl dispatch workspace e+1",
		"on-scroll-down": "hyprctl dispatch workspace e-1"
	},

	"hyprland/window": {
		"max-length": 60,
		"separate-outputs": true
	},

	// ############
	// ## Center ##
	// ############

	"clock": {
		"interval": 60,
		"format": "{:L%A %d %B %Y   -   %H:%M}",
		"max-length": 40,
		"tooltip": false
	},

	// ################
	// ## Right side ##
	// ################

	"custom/packages": {
		"exec": "checkupdates | wc -l",
		"exec-if": "$HOME/.config/waybar/scripts/check_for_upgrades.sh 0",
		"format": "ΎΠφ {}",
		"interval": 45,
		//"on-click": "alacritty -e '.config/waybar/scripts/upgrade.sh'",
		"tooltip": false
	},

	"custom/mediaplayer": {
		"format": "{}",
		"return-type": "json",
		"max-length": 40,
		"escape": true,
		"on-click": "playerctl play-pause",
		"on-scroll-up": "playerctl previous",
		"on-scroll-down": "playerctl next",
		"exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null"
	},

	"tray": {
		"icon-size": 24,
		"spacing": 20
	},

	"idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒ░",
            "deactivated": "ΎΒχ"
        },
        "tooltip": "true"
    },

    // "battery": {
    //     "states": {
    //         "warning": 30,
    //         "critical": 15
    //     },
    //     "format": "{icon} {capacity}%",
    //     "format-charging": "≤░ΓΕ {capacity}%",
    //     "format-plugged": "≤▒αΨ {capacity}%",
    //     "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    //     // "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    //     "on-click": "",
    //     "tooltip": false
    // },

	"temperature": {
		"thermal-zone": 2,
		"interval": 3,
		"hwmon-path": "/sys/class/hwmon/hwmon3/temp2_input",
		"critical-threshold": 90,
		"format-critical": "ΎΒ▒  {temperatureC} ┬░C",
		"format": "{icon} {temperatureC} ┬░C",
		"format-icons": ["ΎΜΜ", "ΎΜΛ", "ΎΜΚ", "ΎΜΙ", "ΎΜΘ"],
		"max-length": 7,
		"min-length": 7,
		"on-click": "alacritty -e '.config/waybar/scripts/sensors.sh'",
		"tooltip": false
	},

	"cpu": {
		"interval": 5,
		"format": "ΎΜδ {usage:1} %",
		"on-click": "alacritty -e 'htop'",
		"tooltip": false
	},

	"memory": {
		"interval": 5,
		"format": "ΎΦ╕ {} %",
		"on-click": "alacritty -e 'htop'"
	},

	// "network": {
	// 	"format-wifi": "ΎΘτ {essid} ({signalStrength}%)",
	// 	"format-ethernet": "ΎηΨ",
	// 	"format-linked": "{ifname} (No IP) ΎηΨ",
