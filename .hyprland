# City:       馃吙 馃叞 馃吇 馃叴 馃唩 馃吋 馃吘, 馃唫 馃吀 馃叢 馃吀 馃吇 馃唸
# Country:    馃吀 馃唭 馃叞 馃吇 馃唸

# Keys 						Action
-----------------------------------------------------------------------------
Meta + L                        Lock the screen
Meta + Del                      Log out
Ctrl + Alt + Del                Reboot
Meta + Ctrl + Alt + Del         Shutdown
Meta + Escape                   Restart 'XDG portals'

Meta + F1                       Toggle 'gamemode'
Meta + F                        Toggle 'fullscreen' on the 'focussed' window.
Meta + S                        Toggle 'split' mode
Meta + P                        Toggle 'pseudo' windows
Meta + T                        Toggle 'floating' for the 'focussed' window
Meta + Alt + Ctrl + T           Toggle 'floating' for 'all' windows
Meta + Z                        Toggle 'zoom'

Meta + W                        Toggle 'Waybar' visibility
Meta + Alt + W                  Reload 'Waybar' (only style.css)
Meta + Alt + Ctrl + W           Reload 'Waybar' (config + style.css)

Meta + V                        Open  the 'clipboard'
Meta + Alt + Ctrl + V           Clear the 'clipboard'

Meta + Alt + Ctrl + N           Restore the last 'notification'

Meta + Q                        Close the 'focussed' window
Meta + Escape                   Close the 'focussed' window

Meta + ArrowUp                  Move the 'focus' on the window on the 'left'   of the current one
Meta + ArrowDown                Move the 'focus' on the window on the 'right'  of the current one
Meta + ArrowLeft                Move the 'focus' on the window on the 'top'    of the current one
Meta + ArrowRight               Move the 'focus' on the window on the 'bottom' of the current one

Meta + Alt + ArrowLeft          Resize the 'focussed' window to the 'left'   by 60 pixels
Meta + Alt + ArrowRight         Resize the 'focussed' window to the 'right'  by 60 pixels
Meta + Alt + ArrowUp            Resize the 'focussed' window to the 'top'    by 60 pixels
Meta + Alt + ArrowDown          Resize the 'focussed' window to the 'bottom' by 60 pixels

Meta + RightMouseButton         Resize the 'window' under the cursor
Meta + LeftMouseButton          Move the 'window' under the cursor

Meta + 1                        Switch to workspace '1'
Meta + 2                        Switch to workspace '2'
Meta + 3                        Switch to workspace '3'
Meta + 4                        Switch to workspace '4'
Meta + 5                        Switch to workspace '5'
Meta + 6                        Switch to workspace '6'
Meta + 7                        Switch to workspace '7'
Meta + 8                        Switch to workspace '8'
Meta + 9                        Switch to workspace '9'
Meta + 0                        Switch to workspace '10'

Meta + Alt + 1                  Move the 'focussed' window and the active workspace to workspace '1'
Meta + Alt + 2                  Move the 'focussed' window and the active workspace to workspace '2'
Meta + Alt + 3                  Move the 'focussed' window and the active workspace to workspace '3'
Meta + Alt + 4                  Move the 'focussed' window and the active workspace to workspace '4'
Meta + Alt + 5                  Move the 'focussed' window and the active workspace to workspace '5'
Meta + Alt + 6                  Move the 'focussed' window and the active workspace to workspace '6'
Meta + Alt + 7                  Move the 'focussed' window and the active workspace to workspace '7'
Meta + Alt + 8                  Move the 'focussed' window and the active workspace to workspace '8'
Meta + Alt + 9                  Move the 'focussed' window and the active workspace to workspace '9'
Meta + Alt + 0                  Move the 'focussed' window and the active workspace to workspace '10'

Meta + Alt + Ctrl + 1           Move the 'focussed' window to workspace '1'
Meta + Alt + Ctrl + 2           Move the 'focussed' window to workspace '2'
Meta + Alt + Ctrl + 3           Move the 'focussed' window to workspace '3'
Meta + Alt + Ctrl + 4           Move the 'focussed' window to workspace '4'
Meta + Alt + Ctrl + 5           Move the 'focussed' window to workspace '5'
Meta + Alt + Ctrl + 6           Move the 'focussed' window to workspace '6'
Meta + Alt + Ctrl + 7           Move the 'focussed' window to workspace '7'
Meta + Alt + Ctrl + 8           Move the 'focussed' window to workspace '8'
Meta + Alt + Ctrl + 9           Move the 'focussed' window to workspace '9'
Meta + Alt + Ctrl + 0           Move the 'focussed' window to workspace '10'

Meta + ScrollDown               Cycle through active 'desktops'
Meta + ScrollUp                 Cycle through active 'desktops' (Reverse)

Menu,                           Open 'Application List'
Print                           Open 'hp-print'
Scroll_lock                     Open 'hyprshot-gui'

Meta + Alt + Ctrl + Return      Open 'Konsole'
Meta + Alt + Return             Open 'Alacritty'
Meta + Alt + A,                 Open 'Amarok'
Meta + Alt + C,                 Open 'Calculator'
Meta + Alt + D                  Open 'Dolphin'
Meta + Alt + F                  Open 'Firefox'
Meta + Alt + G                  Open 'Gimp'
Meta + Alt + I                  Open 'Inkscape'
Meta + Alt + K,                 Open 'KDE Settings'
Meta + Alt + N                  Open 'Netflix'
Meta + Alt + P                  Open 'Color Picker HEX'
Meta + Alt + Ctrl + P           Open 'Color Picker RGB'
Meta + Alt + Q                  Open 'Qbittorrent'
Meta + Alt + S                  Open 'Sublime Text'
Meta + Alt + T                  Open 'Tor Browser'
Meta + Alt + V                  Open 'Virtualbox'